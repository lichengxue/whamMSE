# Install if needed.
# This fixed-history workflow is currently available in the lab branch.
# remotes::install_github("lichengxue/whamMSE@lab", upgrade = "never")
library(wham)
library(whamMSE)
library(dplyr)
library(ggplot2)
library(here)
main.dir <- here::here()
gb_dat_path <- file.path("vignettes", "Data", "GBK.DAT")
